{
  "name": "mn-buyer-intel",
  "version": "0.1.0",
  "private": true,
  "description": "Minnesota public-sector buyer intelligence — maps public buyers, signals, and priorities and matches sellers with an explainable evidence chain.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @mn/db run migrate",
    "capture": "pnpm --filter @mn/scripts run capture",
    "seed": "pnpm --filter @mn/scripts run seed",
    "ingest": "pnpm --filter @mn/scripts run ingest",
    "dev:api": "pnpm --filter @mn/api run dev",
    "dev:web": "pnpm --filter @mn/web run dev",
    "dev": "pnpm run db:migrate && pnpm run seed && concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
