# mn-buyer-intel — environment configuration
# Copy to .env (gitignored) and adjust. All values are optional in development.

# --- Database ---------------------------------------------------------------
# Unset / pglite://<dir>  → PGlite (in-process WASM Postgres, file-backed)  [dev default]
# postgres://user:pass@host:5432/db → real Postgres (pgvector required)     [prod]
# DATABASE_URL=postgres://mn:mn@localhost:5432/mn_buyer_intel

# Override the PGlite data directory (default: ./data/pglite)
# PGLITE_DATA=./data/pglite

# --- API --------------------------------------------------------------------
# PORT=8787
# HOST=0.0.0.0
# LOG_LEVEL=info

# --- Scheduled refresh ------------------------------------------------------
# Cron expression to auto-refresh all live connectors (off when unset).
# Example: every day at 6am. Live fetch hits the real public sources.
# REFRESH_CRON=0 6 * * *

# --- Web (build/dev) --------------------------------------------------------
# API target the Vite dev proxy forwards /api to (default http://localhost:8787)
# API_URL=http://localhost:8787
